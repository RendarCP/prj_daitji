# ============================================================================
# DAITJI Environment Variables - Example
# ============================================================================
# 이 파일을 복사하여 .env.local 파일을 생성하고, 실제 값으로 채워주세요.
# cp .env.local.example .env.local
# ============================================================================

# ----------------------------------------------------------------------------
# Supabase Configuration (필수)
# ----------------------------------------------------------------------------
# Supabase 프로젝트 URL (Project Settings > API > Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Supabase Anon Public Key (Project Settings > API > anon public key)
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# ----------------------------------------------------------------------------
# 개발 환경 설정 (선택)
# ----------------------------------------------------------------------------
# Next.js 개발 서버 포트 (기본값: 3000)
# PORT=3000

# Node 환경 (development, production, test)
# NODE_ENV=development

# ----------------------------------------------------------------------------
# 2차 계획: 인증 시스템 (현재 사용 안 함)
# ----------------------------------------------------------------------------
# Google OAuth
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Kakao OAuth
# NEXT_PUBLIC_KAKAO_CLIENT_ID=
# KAKAO_CLIENT_SECRET=

# ----------------------------------------------------------------------------
# 3차 계획: AI 서비스 (현재 사용 안 함)
# ----------------------------------------------------------------------------
# Open Food Facts API (바코드 스캐너)
# OPEN_FOOD_FACTS_API_KEY=

# Google Cloud Vision API (OCR)
# GOOGLE_CLOUD_VISION_API_KEY=

# ----------------------------------------------------------------------------
# 기타 설정
# ----------------------------------------------------------------------------
# 디버그 모드 활성화
# DEBUG=false

# 로그 레벨 (error, warn, info, debug)
# LOG_LEVEL=info

# ============================================================================
# 설정 가이드
# ============================================================================
#
# 1. Supabase 설정:
#    - https://supabase.com/dashboard 접속
#    - 프로젝트 생성 후 Settings > API 메뉴에서 URL과 Key 복사
#
# 2. 환경 변수 적용:
#    - .env.local 파일은 Git에 커밋되지 않습니다 (.gitignore 설정됨)
#    - 팀원에게 공유할 때는 안전한 방법 사용 (1Password, LastPass 등)
#
# 3. 검증:
#    - npm run dev 실행 후 브라우저에서 http://localhost:3000 접속
#    - 콘솔에서 Supabase 연결 오류가 없는지 확인
#
# ============================================================================
